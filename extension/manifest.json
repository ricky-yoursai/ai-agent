{
  "manifest_version": 3,
  "name": "Aurora AI Browser Agent",
  "version": "1.0.0",
  "description": "AI-powered browser agent — tell it what to do, it clicks and types for you",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
